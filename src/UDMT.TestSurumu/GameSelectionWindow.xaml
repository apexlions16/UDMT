<Window x:Class="UDMT.GameSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UDMT — Oyun Seçimi"
        Width="820" Height="650" MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal">
      <Border Width="46" Height="46" CornerRadius="12" Background="{StaticResource Vurgu}">
        <TextBlock Text="U" FontSize="25" FontWeight="Bold" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="Universal Dubbing Modding Tool" FontSize="19" FontWeight="SemiBold" />
        <TextBlock Text="v0.2.0-beta.1 · Oyun seçimi test sürümü" Foreground="{StaticResource IkincilMetin}" FontSize="12" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="1" Margin="0,30,0,18">
      <TextBlock Text="Önce üzerinde çalışacağınız oyunu seçin" FontSize="27" FontWeight="SemiBold" />
      <TextBlock Margin="0,8,0,0" Foreground="{StaticResource IkincilMetin}" TextWrapping="Wrap"
                 Text="UDMT, seçiminize göre yalnızca o oyuna ait arşiv ve ses araçlarını gösterecektir. Oyunu daha sonra ana ekrandan değiştirebilirsiniz." />
    </StackPanel>

    <ListBox x:Name="OyunListesi" Grid.Row="2" ItemsSource="{Binding}"
             Background="Transparent" BorderThickness="0"
             HorizontalContentAlignment="Stretch"
             SelectionMode="Single"
             MouseDoubleClick="OyunListesi_CiftTik">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="0" />
          <Setter Property="Margin" Value="0,0,0,10" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="FocusVisualStyle" Value="{x:Null}" />
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{StaticResource PanelVurgu}" />
            </Trigger>
          </Style.Triggers>
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Padding="16" CornerRadius="9"
                  Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}"
                  BorderBrush="{StaticResource Cizgi}" BorderThickness="1">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Width="76" Height="48" CornerRadius="8" Background="{StaticResource Panel}">
                <TextBlock Text="{Binding ShortName}" FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource Vurgu}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
              </Border>
              <StackPanel Grid.Column="1" Margin="12,0,18,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}" Margin="0,4,0,0" FontSize="12"
                           Foreground="{StaticResource IkincilMetin}" TextWrapping="Wrap" />
              </StackPanel>
              <Border Grid.Column="2" Padding="10,5" CornerRadius="12" Background="{StaticResource Panel}">
                <TextBlock Text="{Binding ArchiveType}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource IkincilMetin}" />
              </Border>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Grid Grid.Row="3" Margin="0,18,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Oyun dosyalarını değiştirmeden önce yedek alın."
                 Foreground="{StaticResource IkincilMetin}" FontSize="11" VerticalAlignment="Center" />
      <Button Grid.Column="1" Content="Çıkış" Style="{StaticResource IkincilDugme}"
              Margin="0,0,10,0" Click="Cikis_Click" IsCancel="True" />
      <Button Grid.Column="2" Content="Seçilen Oyunu Aç" Style="{StaticResource AnaDugme}"
              Click="Devam_Click" IsDefault="True" />
    </Grid>
  </Grid>
</Window>
