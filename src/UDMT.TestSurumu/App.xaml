<Application x:Class="UDMT.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="ArkaPlan" Color="#111318" />
    <SolidColorBrush x:Key="Panel" Color="#1A1D24" />
    <SolidColorBrush x:Key="PanelVurgu" Color="#242936" />
    <SolidColorBrush x:Key="Cizgi" Color="#343A48" />
    <SolidColorBrush x:Key="Metin" Color="#F4F6FA" />
    <SolidColorBrush x:Key="IkincilMetin" Color="#A7ADBA" />
    <SolidColorBrush x:Key="Vurgu" Color="#7C8CFF" />

    <Style TargetType="Window">
      <Setter Property="Background" Value="{StaticResource ArkaPlan}" />
      <Setter Property="Foreground" Value="{StaticResource Metin}" />
      <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="Button" x:Key="AnaDugme">
      <Setter Property="Background" Value="{StaticResource Vurgu}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="20,10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style TargetType="Button" x:Key="IkincilDugme">
      <Setter Property="Background" Value="{StaticResource PanelVurgu}" />
      <Setter Property="Foreground" Value="{StaticResource Metin}" />
      <Setter Property="BorderBrush" Value="{StaticResource Cizgi}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16,9" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Application.Resources>
</Application>
