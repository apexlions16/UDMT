<Window x:Class="UDMT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UDMT"
        Width="1120" Height="760" MinWidth="860" MinHeight="600"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="64" />
      <RowDefinition Height="*" />
      <RowDefinition Height="32" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Cizgi}" BorderThickness="0,0,0,1">
      <Grid Margin="20,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource Vurgu}" VerticalAlignment="Center">
          <TextBlock Text="U" FontSize="21" FontWeight="Bold" Foreground="White"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="UDMT Format Laboratuvarı" FontSize="15" FontWeight="SemiBold" />
          <TextBlock x:Name="SeciliFormatBaslik" Foreground="{DynamicResource IkincilMetin}" FontSize="12" />
        </StackPanel>
        <Button x:Name="TemaDugmesi" Grid.Column="2" Style="{DynamicResource IkincilDugme}"
                Margin="0,0,10,0" VerticalAlignment="Center" Click="TemaDugmesi_Click" />
        <Button Grid.Column="3" Content="Formatı Değiştir" Style="{DynamicResource IkincilDugme}"
                VerticalAlignment="Center" Click="FormatiDegistir_Click" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <Grid Margin="28">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock x:Name="FormatAdi" FontSize="29" FontWeight="SemiBold" />
            <TextBlock x:Name="FormatAciklamasi" Margin="0,8,0,0" FontSize="13"
                       Foreground="{DynamicResource IkincilMetin}" TextWrapping="Wrap" />
          </StackPanel>
          <Border Grid.Column="1" Margin="20,0,0,0" Padding="14,7" CornerRadius="16"
                  Background="{DynamicResource PanelVurgu}" VerticalAlignment="Top">
            <TextBlock x:Name="Uzantilar" FontWeight="SemiBold" Foreground="{DynamicResource Vurgu}" />
          </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,22,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Margin="0,0,8,0" Padding="16" CornerRadius="9"
                  Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Cizgi}" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Bilinen kullanım alanları" FontWeight="SemiBold" />
              <TextBlock x:Name="BilinenOyunlar" Margin="0,6,0,0" Foreground="{DynamicResource IkincilMetin}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Margin="8,0,0,0" Padding="16" CornerRadius="9"
                  Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Cizgi}" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Format nasıl tanınır?" FontWeight="SemiBold" />
              <TextBlock x:Name="TespitYontemi" Margin="0,6,0,0" Foreground="{DynamicResource IkincilMetin}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,20,0,18" Padding="16" CornerRadius="9"
                Background="{DynamicResource UyariArkaPlan}" BorderBrush="{DynamicResource UyariCizgi}" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="Yeni geliştirme yaklaşımı" FontWeight="SemiBold" Foreground="{DynamicResource UyariBaslik}" />
            <TextBlock Margin="0,5,0,0" TextWrapping="Wrap" Foreground="{DynamicResource UyariMetin}"
                       Text="Önce her format için güvenilir tanıma, salt okunur açma, çıkarma, değiştirme, geri paketleme ve yeniden açarak doğrulama adımları tamamlanacaktır. Oyun profilleri ancak format çekirdeği kararlı olduktan sonra eklenecektir." />
          </StackPanel>
        </Border>

        <StackPanel Grid.Row="3">
          <TextBlock Text="Açma ve geri paketleme adımları" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
          <ItemsControl x:Name="AdimListesi">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,12" Padding="18" CornerRadius="9"
                        Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Cizgi}" BorderThickness="1">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="38" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="{DynamicResource PanelVurgu}">
                      <TextBlock Text="•" FontSize="20" Foreground="{DynamicResource Vurgu}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,20,0">
                      <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Description}" Margin="0,5,0,0" FontSize="12"
                                 Foreground="{DynamicResource IkincilMetin}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="2" Padding="11,6" CornerRadius="13" Background="{DynamicResource PanelVurgu}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource IkincilMetin}" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Cizgi}" BorderThickness="0,1,0,0">
      <Grid Margin="16,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Format merkezli geliştirme planı etkin" FontSize="11"
                   Foreground="{DynamicResource IkincilMetin}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="v0.3.0-beta.1" FontSize="11"
                   Foreground="{DynamicResource IkincilMetin}" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</Window>
